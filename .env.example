# Supabase (server-only — never expose SERVICE_ROLE_KEY to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (server-only)
ANTHROPIC_API_KEY=sk-ant-...

# Apify (candidate sourcing)
APIFY_API_KEY=your-apify-api-key

# Gmail outreach (run scripts/get-gmail-token.mjs once to generate GMAIL_REFRESH_TOKEN)
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_FROM_EMAIL=hiring@flytbase.com
GMAIL_SENDER_NAME=FlytBase Talent

# Unipile — LinkedIn outreach (https://dashboard.unipile.com)
# 1. Sign up and connect your LinkedIn account under Accounts → Add account
# 2. Copy DSN and Access Token from the dashboard home
# 3. Copy the Account ID shown next to your LinkedIn account
# 4. Add a webhook: Webhooks → Add → URL: https://your-app/api/unipile/webhook
#    Event type: messaging.message_received
#    Secret: any strong random string (copy the same value to UNIPILE_WEBHOOK_SECRET)
UNIPILE_DSN=https://api1.unipile.com:13613
UNIPILE_ACCESS_TOKEN=your-unipile-access-token
UNIPILE_LINKEDIN_ACCOUNT_ID=your-linkedin-account-id
UNIPILE_WEBHOOK_SECRET=any-strong-random-string
